{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Storyboard",
  "type": "object",
  "required": ["meta", "scenes"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["topic", "type", "durationSec"],
      "properties": {
        "topic": {"type": "string"},
        "type": {"type": "string", "enum": ["tutorial", "opinion"]},
        "durationSec": {"type": "number"},
        "ratio": {"type": "string", "enum": ["9:16", "16:9", "1:1"], "default": "9:16"},
        "tone": {"type": "string", "enum": ["neutral", "restrained", "conflict"], "default": "neutral"},
        "lang": {"type": "string", "default": "zh"}
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "durationMs"],
        "properties": {
          "id": {"type": "string"},
          "kind": {
            "type": "string",
            "enum": [
              "title-card",
              "hook-card",
              "point-card",
              "screenshot-explain",
              "summary-card",
              "outro-card"
            ]
          },
          "durationMs": {"type": "number"},
          "onScreenText": {"type": "string"},
          "subtitle": {"type": "string"},
          "voiceover": {"type": "string"},
          "asset": {"type": ["string", "null"]},
          "motion": {"type": "string", "default": "cut"},
          "annotations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {"type": "string", "enum": ["highlight-box", "arrow", "circle"]},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "text": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
